	partition 'Fact Purchase Region' = m
		mode: import
		source =
				let
					Source = Csv.Document(File.Contents(CuratedDataFolder & "\fact_purchase_region.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
					Headers = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
					Typed = Table.TransformColumnTypes(Headers, {
						{"GeographyCode", type text},
						{"GeographyName", type text},
						{"PeriodLabel", type text},
						{"MedianHousePrice", type number},
						{"Year", Int64.Type},
						{"PeriodEndDate", type date},
						{"MedianWorkplaceEarnings", type number},
						{"MedianAffordabilityRatio", type number},
						{"MedianFiveYearAverageAffordabilityRatio", type number},
						{"LowerQuartileHousePrice", type number},
						{"LowerQuartileWorkplaceEarnings", type number},
						{"LowerQuartileAffordabilityRatio", type number},
						{"LowerQuartileFiveYearAverageAffordabilityRatio", type number},
						{"GeographyLevel", type text},
						{"AffordabilityThresholdPurchase", type number}
					}, "en-GB")
				in
					Typed

