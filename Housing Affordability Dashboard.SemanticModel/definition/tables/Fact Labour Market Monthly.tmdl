	partition 'Fact Labour Market Monthly' = m
		mode: import
		source =
				let
					Source = Csv.Document(File.Contents(CuratedDataFolder & "\fact_labour_market_monthly.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
					Headers = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
					Typed = Table.TransformColumnTypes(Headers, {
						{"Date", type date},
						{"PeriodLabel", type text},
						{"Year", Int64.Type},
						{"MonthNumber", Int64.Type},
						{"UKAverageHousePrice", type number},
						{"UKHPIIndex", type number},
						{"UKHousePriceMonthlyGrowth", type number},
						{"UKHousePriceAnnualGrowth", type number},
						{"AverageWeeklyEarnings", type number},
						{"AverageWeeklyEarningsAnnualGrowth", type number},
						{"AnnualisedWeeklyEarnings", type number},
						{"UnemploymentRate", type number},
						{"UnemploymentRatePointChange12M", type number},
						{"BankRatePct", type number},
						{"BankRatePctPointChange12M", type number},
						{"HousePriceToAnnualWageRatio", type number},
						{"HousePriceGrowthLessWageGrowth", type number},
						{"UKAverageHousePriceIndexCommonBase", type number},
						{"AverageWeeklyEarningsIndexCommonBase", type number},
						{"UnemploymentRateIndexCommonBase", type number},
						{"CommonIndexBaseDate", type date},
						{"AverageWeeklyEarningsSourcePeriod", type text},
						{"AverageWeeklyEarningsUpdateDate", type text},
						{"UnemploymentRateSourcePeriod", type text},
						{"UnemploymentRateUpdateDate", type text}
					}, "en-GB")
				in
					Typed

