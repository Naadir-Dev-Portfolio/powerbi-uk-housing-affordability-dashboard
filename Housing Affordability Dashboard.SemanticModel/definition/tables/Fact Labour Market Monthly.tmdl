table 'Fact Labour Market Monthly'
	lineageTag: c78d1dc6-7dcd-4fee-9947-39e5511575d9

	measure 'Latest Labour Market Month' =
			CALCULATE(
				MAX('Fact Labour Market Monthly'[Date]),
				FILTER(
					ALL('Fact Labour Market Monthly'),
					NOT ISBLANK('Fact Labour Market Monthly'[AverageWeeklyEarnings])
						&& NOT ISBLANK('Fact Labour Market Monthly'[UKAverageHousePrice])
				)
			)
		formatString: Long Date
		lineageTag: d04e1700-84c7-4fc5-b489-39aa31ff4f45

	measure 'Latest Unemployment Month' =
			CALCULATE(
				MAX('Fact Labour Market Monthly'[Date]),
				FILTER(
					ALL('Fact Labour Market Monthly'),
					NOT ISBLANK('Fact Labour Market Monthly'[UnemploymentRate])
				)
			)
		formatString: Long Date
		lineageTag: 12414a15-799c-43dc-b28f-62c29eab08ab

	measure 'Average Weekly Earnings' = AVERAGE('Fact Labour Market Monthly'[AverageWeeklyEarnings])
		formatString: £#,##0
		lineageTag: b7df1e9f-433e-4c78-b153-3569937e8df4

	measure 'Average Weekly Earnings Latest' =
			VAR _latestDate = [Latest Labour Market Month]
			RETURN
				CALCULATE(
					[Average Weekly Earnings],
					FILTER(
						ALL('Fact Labour Market Monthly'),
						'Fact Labour Market Monthly'[Date] = _latestDate
					)
				)
		formatString: £#,##0
		lineageTag: ba405242-2031-493a-b539-5cbdbfc97773

	measure 'Average Weekly Earnings Annual Growth' = AVERAGE('Fact Labour Market Monthly'[AverageWeeklyEarningsAnnualGrowth])
		formatString: 0.0%
		lineageTag: 660010cb-60e6-4a89-be31-ba60b6f81076

	measure 'Average Weekly Earnings Annual Growth Latest' =
			VAR _latestDate = [Latest Labour Market Month]
			RETURN
				CALCULATE(
					[Average Weekly Earnings Annual Growth],
					FILTER(
						ALL('Fact Labour Market Monthly'),
						'Fact Labour Market Monthly'[Date] = _latestDate
					)
				)
		formatString: 0.0%
		lineageTag: 4b1a6eba-5249-48d0-bb42-5b9c886c857e

	measure 'Unemployment Rate' = AVERAGE('Fact Labour Market Monthly'[UnemploymentRate])
		formatString: 0.0%
		lineageTag: 521ce3c4-47c3-4f21-9169-83db5b31961f

	measure 'Unemployment Rate Latest' =
			VAR _latestDate = [Latest Unemployment Month]
			RETURN
				CALCULATE(
					[Unemployment Rate],
					FILTER(
						ALL('Fact Labour Market Monthly'),
						'Fact Labour Market Monthly'[Date] = _latestDate
					)
				)
		formatString: 0.0%
		lineageTag: 2f601a82-a1cd-47cf-947b-dd81fee82c17

	measure 'Unemployment Rate 12M Point Change' = AVERAGE('Fact Labour Market Monthly'[UnemploymentRatePointChange12M])
		formatString: 0.0%
		lineageTag: cdee471a-3cfa-41f5-b57c-312d768530cf

	measure 'UK Average House Price Labour View' = AVERAGE('Fact Labour Market Monthly'[UKAverageHousePrice])
		formatString: £#,##0
		lineageTag: a0c83d5b-4087-4366-b484-a4d01d8cf886

	measure 'UK House Price Annual Growth Labour View' = AVERAGE('Fact Labour Market Monthly'[UKHousePriceAnnualGrowth])
		formatString: 0.0%
		lineageTag: 17c5c768-36ac-4aab-a3ef-81769a899d05

	measure 'House Price To Annual Wage Ratio' = AVERAGE('Fact Labour Market Monthly'[HousePriceToAnnualWageRatio])
		formatString: 0.0
		lineageTag: 7df3a336-64c7-414c-82e0-fd35768f5219

	measure 'House Price To Annual Wage Ratio Latest' =
			VAR _latestDate = [Latest Labour Market Month]
			RETURN
				CALCULATE(
					[House Price To Annual Wage Ratio],
					FILTER(
						ALL('Fact Labour Market Monthly'),
						'Fact Labour Market Monthly'[Date] = _latestDate
					)
				)
		formatString: 0.0
		lineageTag: 9719b265-9487-4907-9e49-69bb4ea4224a

	measure 'House Price Growth Less Wage Growth' = AVERAGE('Fact Labour Market Monthly'[HousePriceGrowthLessWageGrowth])
		formatString: 0.0%
		lineageTag: 9230a487-8254-45bd-b287-c66c349212e3

	measure 'House Price Growth Less Wage Growth Latest' =
			VAR _latestDate = [Latest Labour Market Month]
			RETURN
				CALCULATE(
					[House Price Growth Less Wage Growth],
					FILTER(
						ALL('Fact Labour Market Monthly'),
						'Fact Labour Market Monthly'[Date] = _latestDate
					)
				)
		formatString: 0.0%
		lineageTag: 64ace836-f2e8-40b4-a578-fa117be213a7

