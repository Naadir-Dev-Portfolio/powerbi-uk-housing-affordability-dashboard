	partition 'Fact UK Purchase Country Region Median' = m
		mode: import
		source =
				let
					Source = Csv.Document(File.Contents(CuratedDataFolder & "\fact_uk_purchase_country_region_median.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
					Headers = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
					Typed = Table.TransformColumnTypes(Headers, {
						{"GeographyCode", type text},
						{"GeographyName", type text},
						{"PeriodLabel", type text},
						{"MedianHousePrice", type number},
						{"Year", Int64.Type},
						{"PeriodEndDate", type date},
						{"MedianEquivalisedDisposableIncome", type number},
						{"MedianPurchaseAffordabilityRatioUK", type number},
						{"GeographyLevel", type text},
						{"AffordabilityThresholdPurchase", type number}
					}, "en-GB")
				in
					Typed

