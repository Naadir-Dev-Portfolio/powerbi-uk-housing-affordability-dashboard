table 'Fact UK Purchase Country Region Median'
	lineageTag: 585825ff-f90a-4773-be27-5983a58a09cd

	measure 'UK Purchase Latest Year' = CALCULATE(MAX('Fact UK Purchase Country Region Median'[Year]), REMOVEFILTERS('Dim Date'))
		formatString: 0
		lineageTag: a5f3534a-73a0-4288-914a-36bc6aed6cb7

	measure 'UK Purchase Ratio' = AVERAGE('Fact UK Purchase Country Region Median'[MedianPurchaseAffordabilityRatioUK])
		formatString: 0.0
		lineageTag: 6d57a7c1-4fdb-4718-9be1-9b311626f3bc

	measure 'UK Purchase Ratio Latest' =
			VAR _latestYear = [UK Purchase Latest Year]
			RETURN
				CALCULATE(
					[UK Purchase Ratio],
					KEEPFILTERS('Dim Date'[Year] = _latestYear)
				)
		formatString: 0.0
		lineageTag: 1ce9667c-dc9d-4471-8e8f-970900d70134

	measure 'UK Median House Price' = AVERAGE('Fact UK Purchase Country Region Median'[MedianHousePrice])
		formatString: £#,##0
		lineageTag: bd8d1d32-0fe5-46b1-8836-939494f3114f

	measure 'UK Median Disposable Income' = AVERAGE('Fact UK Purchase Country Region Median'[MedianEquivalisedDisposableIncome])
		formatString: £#,##0
		lineageTag: d34279cb-cf1e-4958-ae2c-2869b55df3c1

	column GeographyCode
		dataType: string
