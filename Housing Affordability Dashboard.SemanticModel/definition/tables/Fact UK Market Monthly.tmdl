table 'Fact UK Market Monthly'
	lineageTag: fb7f4329-018e-44ac-8ba2-c8dbb7e46904

	measure 'Latest UK Market Month' =
			CALCULATE(
				MAX('Fact UK Market Monthly'[Date]),
				FILTER(
					ALL('Fact UK Market Monthly'),
					'Fact UK Market Monthly'[Scenario] = "Actual"
						&& NOT ISBLANK('Fact UK Market Monthly'[DisplayPrice])
				)
			)
		formatString: Long Date
		lineageTag: e96b5226-7781-4acb-b0af-1c9e212b31af

	measure 'UK Average House Price' = AVERAGE('Fact UK Market Monthly'[DisplayPrice])
		formatString: £#,##0
		lineageTag: c579688b-fae7-48cb-9756-2843ad684c74

	measure 'UK Average House Price Latest' =
			VAR _latestDate = [Latest UK Market Month]
			RETURN
				CALCULATE(
					[UK Average House Price],
					FILTER(
						ALL('Fact UK Market Monthly'),
						'Fact UK Market Monthly'[Date] = _latestDate
							&& 'Fact UK Market Monthly'[Scenario] = "Actual"
					)
				)
		formatString: £#,##0
		lineageTag: 6cbbcd7f-d591-4057-a440-7a0404b1eb7f

	measure 'UK HPI Index' = AVERAGE('Fact UK Market Monthly'[Index])
		formatString: 0.0
		lineageTag: 44207fcd-17c6-4dbb-9907-3c761d6f4b18

	measure 'UK HPI Index Latest' =
			VAR _latestDate = [Latest UK Market Month]
			RETURN
				CALCULATE(
					[UK HPI Index],
					FILTER(
						ALL('Fact UK Market Monthly'),
						'Fact UK Market Monthly'[Date] = _latestDate
							&& 'Fact UK Market Monthly'[Scenario] = "Actual"
					)
				)
		formatString: 0.0
		lineageTag: f8a5e791-ff93-49d7-a1b4-2c062df25b4b

	measure 'UK HPI Annual Change' = AVERAGE('Fact UK Market Monthly'[AnnualChangePct])
		formatString: 0.0%
		lineageTag: 9394c4bc-77d0-4527-8f03-c71d748a57d7

	measure 'UK HPI Annual Change Latest' =
			VAR _latestDate = [Latest UK Market Month]
			RETURN
				CALCULATE(
					[UK HPI Annual Change],
					FILTER(
						ALL('Fact UK Market Monthly'),
						'Fact UK Market Monthly'[Date] = _latestDate
							&& 'Fact UK Market Monthly'[Scenario] = "Actual"
					)
				)
		formatString: 0.0%
		lineageTag: d522240f-e6ee-4d24-9650-4c2bc068da7d

	measure 'UK Bank Rate' = AVERAGE('Fact UK Market Monthly'[BankRatePct])
		formatString: 0.00%
		lineageTag: 647b5fd4-5785-4b2c-a54d-bd44235c35b5

	measure 'UK Bank Rate Latest At HPI Month' =
			VAR _latestDate = [Latest UK Market Month]
			RETURN
				CALCULATE(
					[UK Bank Rate],
					FILTER(
						ALL('Fact UK Market Monthly'),
						'Fact UK Market Monthly'[Date] = _latestDate
							&& 'Fact UK Market Monthly'[Scenario] = "Actual"
					)
				)
		formatString: 0.00%
		lineageTag: dc601c13-7029-4b8a-a16a-ed41acfa72ad

	measure 'UK Rate vs Price Growth Correlation 36M' =
			VAR _latestDate = [Latest UK Market Month]
			RETURN
				CALCULATE(
					AVERAGE('Fact UK Market Monthly'[RatePriceCorrelation36M]),
					FILTER(
						ALL('Fact UK Market Monthly'),
						'Fact UK Market Monthly'[Date] = _latestDate
							&& 'Fact UK Market Monthly'[Scenario] = "Actual"
					)
				)
		formatString: 0.00
		lineageTag: 45da4d93-0354-49fb-8cb1-84d8d430083e

	measure 'UK Forecast End Month' =
			CALCULATE(
				MAX('Fact UK Market Monthly'[Date]),
				FILTER(
					ALL('Fact UK Market Monthly'),
					'Fact UK Market Monthly'[Scenario] = "Forecast"
						&& NOT ISBLANK('Fact UK Market Monthly'[DisplayPrice])
				)
			)
		formatString: Long Date
		lineageTag: 10b6af5f-2b95-4775-9477-1e583166d4fe

	measure 'UK Forecast End Price' =
			VAR _forecastDate = [UK Forecast End Month]
			RETURN
				CALCULATE(
					[UK Average House Price],
					FILTER(
						ALL('Fact UK Market Monthly'),
						'Fact UK Market Monthly'[Date] = _forecastDate
							&& 'Fact UK Market Monthly'[Scenario] = "Forecast"
					)
				)
		formatString: £#,##0
		lineageTag: c416996f-13eb-473b-8ad2-aab781ee362f

	measure 'UK Forecast Price 12M Change' = DIVIDE([UK Forecast End Price] - [UK Average House Price Latest], [UK Average House Price Latest])
		formatString: 0.0%
		lineageTag: b3206411-6a8e-4a9b-99d9-ceef7d960239

	measure 'UK HPI Growth 12M After Rate Move' = AVERAGE('Fact UK Market Monthly'[HousePriceAnnualGrowthLead12M])
		formatString: 0.0%
		lineageTag: 91cd0d52-ff54-4b1c-86ad-0effd7140abf

