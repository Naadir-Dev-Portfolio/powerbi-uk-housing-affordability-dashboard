	partition 'Fact UK Market Monthly' = m
		mode: import
		source =
				let
					Source = Csv.Document(File.Contents(CuratedDataFolder & "\fact_uk_market_monthly.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
					Headers = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
					Typed = Table.TransformColumnTypes(Headers, {
						{"Date", type date},
						{"PeriodLabel", type text},
						{"Year", Int64.Type},
						{"MonthNumber", Int64.Type},
						{"Scenario", type text},
						{"ScenarioSort", Int64.Type},
						{"ForecastMethod", type text},
						{"AveragePrice", type number},
						{"AveragePriceSA", type number},
						{"DisplayPrice", type number},
						{"ActualPriceForPeriod", type number},
						{"ForecastPrice", type number},
						{"Index", type number},
						{"IndexSeasonallyAdjusted", type number},
						{"MonthlyChangePct", type number},
						{"AnnualChangePct", type number},
						{"SalesVolume", type number},
						{"BankRatePct", type number},
						{"BankRatePctPointChange1M", type number},
						{"BankRatePctPointChange12M", type number},
						{"BankRateLag12M", type number},
						{"RatePriceCorrelation36M", type number},
						{"HousePriceAnnualGrowthLead12M", type number},
						{"BankRateChangeBand12M", type text},
						{"BankRateChangeBandSort", Int64.Type},
						{"CrisisPeriod", type text},
						{"MarketPeriod", type text},
						{"IsMarketStressPeriod", type logical}
					}, "en-GB")
				in
					Typed

